{
  "version": 2,
  "builds": [
    { "src": "package.json", "use": "@vercel/next" },
    { "src": "car-rental-backend/server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(auth|vehicles|bookings)/(.*)", "dest": "/car-rental-backend/server.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
